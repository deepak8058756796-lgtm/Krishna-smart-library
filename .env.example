# Environment Variable Declarations

# Google Gemini API key used in server-side features
GEMINI_API_KEY=

# Hosted URL of the application
APP_URL=

# Fast2SMS OTP Gateway Credentials
FAST2SMS_API_KEY=

# MSG91 OTP Gateway Credentials
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Twilio Credentials (Global fallback SMS route)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

